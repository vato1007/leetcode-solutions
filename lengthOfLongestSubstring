class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        vector<int> lastSeen(256, -1);
        int left = 0, answer = 0;

        for (int right = 0; right < s.size(); right++) {
            unsigned char ch = s[right];

            // Move left past the previous occurrence of this character.
            if (lastSeen[ch] >= left) {
                left = lastSeen[ch] + 1;
            }

            lastSeen[ch] = right;
            answer = max(answer, right - left + 1);
        }

        return answer;
    }
};
