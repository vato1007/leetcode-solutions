
class Solution {
public:
    int dfs(TreeNode* root, int curr) {
        if (!root) return 0;

        curr = (curr << 1) | root->val;

        if (!root->left && !root->right)
            return curr;

        return dfs(root->left, curr) + dfs(root->right, curr);
    }

    int sumRootToLeaf(TreeNode* root) {
        return dfs(root, 0);
    }
};
